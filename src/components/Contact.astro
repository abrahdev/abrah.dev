---
import MailIcon from "./icons/MailIcon.astro";
---

<h2 class="text-3xl font-semibold pb-8 gap-x-2 flex items-center">
  <MailIcon class="size-7" />
  Contacto
</h2>

<div class="flex flex-col gap-6">
  <p class="text-lg opacity-80">
    ¿Tienes algún proyecto en mente, necesitas ayuda con tu infraestructura o
    simplemente quieres charlar sobre tecnología? ¡Ponte en contacto conmigo!
  </p>

  <form
    class="flex flex-col gap-4"
    action="mailto:abraham@abrah.dev"
    method="POST"
    enctype="text/plain"
  >
    <div class="flex flex-col sm:flex-row gap-4">
      <input
        type="text"
        name="name"
        placeholder="Tu nombre"
        class="w-full px-4 py-3 rounded-full bg-gray-100 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500 transition"
        required
      />
      <input
        type="email"
        name="email"
        placeholder="Tu correo electrónico"
        class="w-full px-4 py-3 rounded-full bg-gray-100 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500 transition"
        required
      />
    </div>
    <textarea
      name="message"
      rows="4"
      placeholder="¿En qué te puedo ayudar?"
      class="w-full px-4 py-3 rounded-2xl bg-gray-100 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500 transition"
      required></textarea>

    <button
      type="submit"
      class="w-full sm:w-auto self-start px-8 py-3 rounded-full bg-gradient-to-r from-purple-400 via-pink-500 to-red-500 text-white font-medium hover:scale-105 transition duration-300"
    >
      Enviar mensaje
    </button>
  </form>
</div>
